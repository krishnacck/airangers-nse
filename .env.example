# ============================================
# Fyers API Configuration
# Get credentials from: https://myapi.fyers.in/dashboard
# ============================================
FYERS_APP_ID=your_app_id_here
FYERS_SECRET_KEY=your_secret_key_here
FYERS_REDIRECT_URL=auto
FYERS_ACCESS_TOKEN=

# ============================================
# Server Configuration
# ============================================
PORT=3000
NODE_ENV=development
PRODUCTION_DOMAIN=airangers.in

# ============================================
# Paper Trading Configuration
# ============================================
PAPER_TRADE_CAPITAL=100000
MAX_POSITION_SIZE=25000
STOP_LOSS_PERCENT=2.5
TARGET_PERCENT=4

# ============================================
# Auto-Trader (Background Scheduler)
# ============================================
AUTO_START_SCHEDULER=false
AUTO_START_DATADUMP=true
SCAN_INTERVAL_SECONDS=60
MAX_TRADES_PER_DAY=10
AUTO_CLOSE_BEFORE_CLOSE_MINUTES=5
